---
import SectionLabel from '@/components/ui/SectionLabel.astro';
import Button from '@/components/ui/Button.astro';

const elisaCards = [
  { letter: 'E', num: '01', title: 'Energía Solar',  desc: 'Panel de 100W monocristalino con 5 noches de autonomía sin sol.' },
  { letter: 'L', num: '02', title: 'Luz LED',         desc: '2.500 lm de iluminación IP67 con vida útil de 50.000 horas.' },
  { letter: 'I', num: '03', title: 'Inclusiva',       desc: 'WiFi de 100m sin cableado, internet gratis para comunidades remotas.' },
  { letter: 'S', num: '04', title: 'Sostenible',      desc: 'Batería LiFePO₄ 150Ah. 15+ años de vida. Aluminio reciclado.' },
  { letter: 'A', num: '05', title: 'Accesible',       desc: 'Instalada en menos de 8 horas. Sin obra civil. Sin red eléctrica.' },
];

const certifications = 'ISO 9001 · RoHS · CE · GDPR ALIGNED FIRMWARE';
const techspecs      = 'PANEL 100W · BATERÍA 150Ah · WiFi 100M · AUTONOMÍA 5 NOCHES · VIDA ÚTIL 15+ AÑOS';
---

<section class="section section--soft elisa" id="elisa" aria-labelledby="elisa-heading">
  <div class="container">

    <!-- ── Zona 1: Header ── -->
    <div class="elisa__header gsap-hidden">

      <p class="elisa__ficha-label" aria-hidden="true">FICHA TÉCNICA · REV. 4.2</p>

      <div class="elisa__header-body">

        <div class="elisa__header-text">
          <SectionLabel>El producto</SectionLabel>
          <h2 id="elisa-heading" class="elisa__headline">
            ELISA®: luz e internet,<br />todo en un poste solar.
          </h2>
          <p class="elisa__subhead">
            Diseñada para operar de forma autónoma durante más de 15 años,
            ELISA® combina energía solar, almacenamiento de litio y conectividad
            WiFi en una infraestructura compacta que no requiere red eléctrica
            ni obra civil.
          </p>
        </div>

        <div class="elisa__visual-wrap" aria-hidden="true">
          <div class="elisa__product-card">
            <svg
              class="elisa__svg"
              viewBox="0 0 260 460"
              xmlns="http://www.w3.org/2000/svg"
              role="img"
              aria-label="Ilustración del poste solar ELISA®"
            >
              <defs>
                <radialGradient id="elisaGlow" cx="65%" cy="62%" r="45%">
                  <stop offset="0%"   stop-color="#38b6ff" stop-opacity="0.35"/>
                  <stop offset="100%" stop-color="#38b6ff" stop-opacity="0"/>
                </radialGradient>
                <linearGradient id="panelGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%"   stop-color="#1a9ee0"/>
                  <stop offset="100%" stop-color="#0d6fa3"/>
                </linearGradient>
              </defs>

              <ellipse cx="178" cy="292" rx="72" ry="52" fill="url(#elisaGlow)"/>

              <g transform="rotate(-7, 100, 88)">
                <rect x="38" y="52" width="122" height="72" rx="5" fill="#0D1A2E"/>
                <rect x="43" y="57" width="112" height="62" rx="3" fill="url(#panelGrad)"/>
                <g stroke="rgba(255,255,255,0.28)" stroke-width="0.8" fill="none">
                  <line x1="80"  y1="57" x2="80"  y2="119"/>
                  <line x1="117" y1="57" x2="117" y2="119"/>
                  <line x1="43"  y1="78" x2="155" y2="78"/>
                  <line x1="43"  y1="98" x2="155" y2="98"/>
                </g>
              </g>

              <g stroke="#38b6ff" stroke-width="1.8" stroke-linecap="round" opacity="0.25">
                <line x1="192" y1="42" x2="204" y2="30"/>
                <line x1="205" y1="62" x2="220" y2="57"/>
                <line x1="188" y1="24" x2="188" y2="10"/>
                <line x1="210" y1="80" x2="225" y2="82"/>
              </g>

              <rect x="122" y="110" width="14" height="265" rx="4" fill="#0D1A2E"/>
              <path d="M 129 235 Q 148 235 170 235" stroke="#0D1A2E" stroke-width="9" fill="none" stroke-linecap="round"/>

              <rect x="158" y="225" width="44" height="20" rx="7" fill="#0D1A2E"/>
              <rect x="163" y="229" width="34" height="12" rx="4" fill="#38b6ff" opacity="0.85"/>
              <ellipse cx="180" cy="251" rx="18" ry="6" fill="#38b6ff" opacity="0.25"/>
              <ellipse cx="180" cy="262" rx="12" ry="5" fill="#38b6ff" opacity="0.12"/>

              <g stroke="#38b6ff" stroke-width="1.6" fill="none" stroke-linecap="round" opacity="0.55">
                <path d="M 116 162 Q 129 156 142 162"/>
                <path d="M 110 153 Q 129 144 148 153"/>
                <path d="M 104 144 Q 129 132 154 144"/>
              </g>
              <circle cx="129" cy="169" r="2.5" fill="#38b6ff" opacity="0.7"/>

              <rect x="114" y="375" width="30" height="8" rx="3" fill="#0D1A2E" opacity="0.18"/>
              <rect x="108" y="383" width="42" height="4" rx="2" fill="#0D1A2E" opacity="0.10"/>

              <circle cx="28"  cy="145" r="2.5" fill="#38b6ff" opacity="0.3"/>
              <circle cx="228" cy="115" r="2"   fill="#38b6ff" opacity="0.25"/>
              <circle cx="220" cy="210" r="3"   fill="#38b6ff" opacity="0.18"/>
              <circle cx="36"  cy="305" r="2"   fill="#38b6ff" opacity="0.2"/>
              <circle cx="235" cy="320" r="1.8" fill="#38b6ff" opacity="0.15"/>
            </svg>

            <div class="elisa__badge">
              <span class="elisa__badge-dot" aria-hidden="true"></span>
              Producción activa · 100 unidades/día
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ── Zona 2: 5 tarjetas E·L·I·S·A ── -->
    <ul class="elisa__cards" role="list" aria-label="Qué significa cada letra de ELISA®">
      {elisaCards.map(card => (
        <li class="elisa__card gsap-hidden" role="listitem">
          <div class="elisa__card-top">
            <span class="elisa__card-letter" aria-hidden="true">{card.letter}</span>
            <span class="elisa__card-num" aria-hidden="true">{card.num}</span>
          </div>
          <div class="elisa__card-divider" aria-hidden="true"></div>
          <p class="elisa__card-title">{card.title}</p>
          <p class="elisa__card-desc">{card.desc}</p>
        </li>
      ))}
    </ul>

    <!-- ── Zona 3: Barra de specs inferior ── -->
    <div class="elisa__specbar gsap-hidden" aria-label="Certificaciones y especificaciones técnicas">
      <p class="elisa__specbar-row">{certifications}</p>
      <p class="elisa__specbar-row">{techspecs}</p>
    </div>

    <!-- ── CTAs ── -->
    <div class="elisa__cta gsap-hidden">
      <Button href="/empresas#contacto" size="lg" arrow>
        Solicita una demo
      </Button>
      <Button href="/impacto" variant="secondary" size="lg">
        Ver impacto real
      </Button>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.elisa__header', { opacity: 0, y: 32 }, {
    opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
    scrollTrigger: { trigger: '.elisa', start: 'top 78%' },
  });

  gsap.fromTo('.elisa__card', { opacity: 0, y: 20 }, {
    opacity: 1, y: 0, duration: 0.6, stagger: 0.10, ease: 'power3.out',
    scrollTrigger: { trigger: '.elisa__cards', start: 'top 80%' },
  });

  gsap.fromTo('.elisa__specbar, .elisa__cta', { opacity: 0, y: 16 }, {
    opacity: 1, y: 0, duration: 0.6, stagger: 0.12, ease: 'power3.out',
    scrollTrigger: { trigger: '.elisa__specbar', start: 'top 88%' },
  });
</script>

<style>
  /* ── Header ── */
  .elisa__header {
    margin-bottom: var(--space-12);
  }

  .elisa__ficha-label {
    display: block;
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-align: right;
    margin-bottom: var(--space-4);
  }

  .elisa__header-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 900px) {
    .elisa__header-body { grid-template-columns: 1fr 320px; }
  }

  .elisa__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
  }

  .elisa__subhead {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 520px;
  }

  /* ── Visual del producto ── */
  .elisa__visual-wrap {
    display: flex;
    justify-content: center;
  }

  .elisa__product-card {
    background: var(--color-bg);
    border: 1px solid rgba(56, 182, 255, 0.15);
    border-radius: var(--radius-xl);
    padding: var(--space-8) var(--space-6) var(--space-6);
    box-shadow: var(--shadow-md);
    width: 100%;
    max-width: 300px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .elisa__svg {
    width: 100%;
    max-width: 200px;
    height: auto;
  }

  .elisa__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-success);
    background: rgba(22, 163, 74, 0.08);
    border: 1px solid rgba(22, 163, 74, 0.25);
    border-radius: var(--radius-pill);
    padding: 6px 14px;
    white-space: nowrap;
  }

  .elisa__badge-dot {
    width: 7px;
    height: 7px;
    flex-shrink: 0;
    background: var(--color-success);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  /* ── 5 tarjetas E·L·I·S·A ── */
  .elisa__cards {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(56, 182, 255, 0.10);
    border: 1px solid rgba(56, 182, 255, 0.10);
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 680px) {
    .elisa__cards { grid-template-columns: repeat(5, 1fr); }
  }

  /* Última tarjeta ocupa el ancho completo en mobile (2 cols) */
  .elisa__cards > li:last-child { grid-column: span 2; }

  @media (min-width: 680px) {
    .elisa__cards > li:last-child { grid-column: span 1; }
  }

  .elisa__card {
    background: var(--color-bg);
    padding: var(--space-6);
    cursor: default;
    transition:
      background var(--duration-normal) var(--easing-smooth),
      transform var(--duration-normal) var(--easing-smooth);
  }

  .elisa__card:hover {
    background: var(--color-primary-light);
    transform: translateY(-2px);
  }

  .elisa__card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-3);
  }

  .elisa__card-letter {
    font-family: var(--font-display);
    font-size: clamp(60px, 8vw, 88px);
    font-weight: var(--weight-black);
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .elisa__card-num {
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    margin-top: var(--space-2);
  }

  .elisa__card-divider {
    width: 28px;
    height: 2px;
    background: var(--color-primary);
    opacity: 0.45;
    margin-bottom: var(--space-4);
  }

  .elisa__card-title {
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .elisa__card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  /* ── Barra de specs inferior ── */
  .elisa__specbar {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6) 0;
    border-top: 1px solid rgba(56, 182, 255, 0.12);
    border-bottom: 1px solid rgba(56, 182, 255, 0.12);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 900px) {
    .elisa__specbar {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .elisa__specbar-row {
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* ── CTAs ── */
  .elisa__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
</style>
