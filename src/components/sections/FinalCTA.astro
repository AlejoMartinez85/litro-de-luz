---
import Button from '@/components/ui/Button.astro';
---

<section class="section section--primary final-cta" aria-labelledby="cta-heading">
  <div class="container final-cta__inner">
    <h2 id="cta-heading" class="final-cta__headline gsap-hidden">
      Tu inversión ESG<br />merece evidencia real.
    </h2>
    <p class="final-cta__subhead gsap-hidden">
      Únete a las empresas que ya miden impacto con datos físicos verificados — no estimaciones.
    </p>
    <div class="final-cta__ctas gsap-hidden">
      <Button href="/empresas#contacto" size="lg" arrow>
        Schedule a Demo
      </Button>
      <Button href="#impact-exchange" variant="ghost" size="lg">
        Ver Impact Exchange®
      </Button>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.final-cta .gsap-hidden', { opacity: 0, y: 30 }, {
    opacity: 1, y: 0, duration: 0.7, stagger: 0.15, ease: 'power3.out',
    scrollTrigger: { trigger: '.final-cta', start: 'top 75%' },
  });
</script>

<style>
  .final-cta__inner {
    text-align: center;
    padding-block: var(--space-24);
  }

  .final-cta__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  .final-cta__subhead {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-10);
    max-width: 480px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .final-cta__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }
</style>
