---
import SectionLabel from '@/components/ui/SectionLabel.astro';

const steps = [
  {
    num: '01',
    title: 'Empresas convierten emisiones en luz',
    desc: 'Corporaciones financian instalaciones de ELISA® a través de bonos de carbono certificados. Cada aportación genera un impacto ESG verificable y reportable.',
    color: 'var(--color-primary)',
  },
  {
    num: '02',
    title: 'Fabricamos e instalamos ELISA®',
    desc: 'Producimos 100 postes solares por día e instalamos en comunidades sin red eléctrica. Sin obra civil, sin cableado. Lista en menos de 8 horas.',
    color: 'var(--color-accent)',
  },
  {
    num: '03',
    title: 'Comunidades y empresas ganan',
    desc: 'Las comunidades reciben luz, internet y educación. Las empresas obtienen reportes ESG automáticos, certificaciones y deducción tributaria.',
    color: 'var(--color-primary-dark)',
  },
];
---

<section class="section section--soft how" id="como-funciona" aria-labelledby="how-heading">
  <div class="container">
    <div class="how__header gsap-hidden">
      <SectionLabel>Cómo funciona</SectionLabel>
      <h2 id="how-heading" class="how__headline">
        De CO₂ a comunidades<br />iluminadas en 3 pasos.
      </h2>
    </div>

    <ol class="how__steps" aria-label="Pasos del proceso">
      {steps.map((step, i) => (
        <li class="how__step gsap-hidden">
          <div class="how__step-num" style={`--step-color: ${step.color}`} aria-hidden="true">
            {step.num}
          </div>
          <div class="how__step-body">
            <h3 class="how__step-title">{step.title}</h3>
            <p class="how__step-desc">{step.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="how__connector" aria-hidden="true">
              <svg viewBox="0 0 40 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 12 H32 M24 4 L40 12 L24 20" stroke="var(--color-primary)" stroke-width="1.5"
                      stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.4"/>
              </svg>
            </div>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.how__header', { opacity: 0, y: 28 }, {
    opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
    scrollTrigger: { trigger: '.how', start: 'top 78%' },
  });

  gsap.fromTo('.how__step', { opacity: 0, y: 32 }, {
    opacity: 1, y: 0, duration: 0.65, stagger: 0.18, ease: 'power3.out',
    scrollTrigger: { trigger: '.how__steps', start: 'top 80%' },
  });
</script>

<style>
  .how__header {
    margin-bottom: var(--space-16);
    max-width: 600px;
  }

  .how__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-top: var(--space-3);
  }

  .how__steps {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .how__steps {
      grid-template-columns: 1fr auto 1fr auto 1fr;
      align-items: start;
      gap: 0;
    }
  }

  .how__step {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .how__step {
      padding: 0 var(--space-6);
    }
  }

  .how__step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--step-color, var(--color-primary));
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: var(--weight-black);
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .how__step-title {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .how__step-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .how__connector {
    display: none;
  }

  @media (min-width: 768px) {
    .how__connector {
      display: flex;
      align-items: flex-start;
      padding-top: 16px;
    }

    .how__connector svg {
      width: 40px;
      height: 24px;
      flex-shrink: 0;
    }
  }
</style>
