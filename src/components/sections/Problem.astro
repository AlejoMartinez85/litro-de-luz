---
import SectionLabel from '@/components/ui/SectionLabel.astro';
import { problemStats, csrdStats } from '@/data/metrics';
import { formatNumber } from '@/utils/formatNumber';
---

<section class="section section--dark problem" id="problema" aria-labelledby="problem-heading">
  <div class="container">
    <SectionLabel light>Por qué existimos</SectionLabel>
    <h2 id="problem-heading" class="problem__headline gsap-hidden">
      El impacto real es invisible.<br /><span class="problem__headline-accent">Hasta ahora.</span>
    </h2>

    <div class="problem__stats">
      {problemStats.map(stat => (
        <article class="problem__stat gsap-hidden">
          <p class="problem__stat-number">
            {formatNumber(stat.value)}<span class="problem__stat-suffix">{stat.suffix ?? ''}</span>
          </p>
          <p class="problem__stat-label">{stat.label}</p>
          <p class="problem__stat-desc">{stat.description}</p>
        </article>
      ))}
    </div>

    <hr class="problem__divider gsap-hidden" />

    <p class="problem__b2b-label gsap-hidden">El problema del cliente B2B</p>
    <div class="problem__stats problem__stats--csrd">
      {csrdStats.map(stat => (
        <article class="problem__stat gsap-hidden">
          <p class="problem__stat-number">
            {formatNumber(stat.value)}<span class="problem__stat-suffix">{stat.suffix ?? ''}</span>
          </p>
          <p class="problem__stat-label">{stat.label}</p>
          <p class="problem__stat-desc">{stat.description}</p>
        </article>
      ))}
    </div>

    <p class="problem__closing gsap-hidden">
      Las empresas invierten millones en ESG. Sin datos físicos verificables,
      es solo una promesa.<br />
      <strong>Litro de Luz® convierte infraestructura real en evidencia auditable.</strong>
    </p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.problem .gsap-hidden', { opacity: 0, y: 30 }, {
    opacity: 1, y: 0, duration: 0.7, stagger: 0.15, ease: 'power3.out',
    scrollTrigger: { trigger: '.problem', start: 'top 75%' },
  });
</script>

<style>
  .problem__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    color: var(--color-white);
    margin-bottom: var(--space-16);
    letter-spacing: -0.02em;
  }

  .problem__headline-accent {
    color: var(--color-primary);
  }

  .problem__divider {
    border: none;
    border-top: 1px solid rgba(56, 182, 255, 0.15);
    margin-bottom: var(--space-8);
  }

  .problem__b2b-label {
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: var(--space-8);
  }

  .problem__stats--csrd {
    margin-bottom: var(--space-16);
  }

  .problem__stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-16);
  }

  @media (min-width: 600px) {
    .problem__stats { grid-template-columns: repeat(3, 1fr); }
  }

  .problem__stat {
    border-left: 3px solid var(--color-primary);
    padding-left: var(--space-6);
  }

  .problem__stat-number {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 72px);
    font-weight: var(--weight-black);
    color: var(--color-white);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .problem__stat-suffix {
    color: var(--color-primary);
  }

  .problem__stat-label {
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    color: var(--color-white);
    margin-bottom: var(--space-1);
  }

  .problem__stat-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .problem__closing {
    font-size: var(--text-h3);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .problem__closing strong {
    color: var(--color-white);
  }
</style>
