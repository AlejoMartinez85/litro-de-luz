---
import type { ButtonVariant, ButtonSize } from '@/types';

interface Props {
  href?: string;
  variant?: ButtonVariant;
  size?: ButtonSize;
  class?: string;
  arrow?: boolean;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  arrow = false,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class={`btn btn--${variant} btn--${size} ${className}`}
  {...rest}
>
  <slot />
  {arrow && <span class="btn__arrow" aria-hidden="true">→</span>}
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-pill);
    border: 2px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition:
      background var(--duration-fast) var(--easing-smooth),
      color var(--duration-fast) var(--easing-smooth),
      box-shadow var(--duration-fast) var(--easing-smooth),
      transform var(--duration-fast) var(--easing-spring);
    white-space: nowrap;
  }

  .btn:hover { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  /* Variantes */
  .btn--primary {
    background: var(--color-primary-dark);
    color: var(--color-white);
  }
  .btn--primary:hover {
    background: var(--color-primary);
    box-shadow: var(--shadow-cta);
  }

  .btn--secondary {
    background: transparent;
    color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
  }
  .btn--secondary:hover {
    background: var(--color-primary-light);
  }

  .btn--ghost {
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.2);
  }
  .btn--ghost:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Tamaños */
  .btn--sm  { font-size: var(--text-sm);  padding: 8px 18px; }
  .btn--md  { font-size: var(--text-body); padding: 12px 26px; }
  .btn--lg  { font-size: var(--text-body-lg); padding: 16px 36px; }

  .btn__arrow {
    transition: transform var(--duration-fast) var(--easing-smooth);
  }
  .btn:hover .btn__arrow { transform: translateX(4px); }
</style>
