---
interface Props {
  value: number;
  suffix?: string;
  label: string;
  description?: string;
  animate?: boolean;
}

const { value, suffix = '', label, description, animate = true } = Astro.props;
---

<article
  class="metric-card"
  data-animate={animate}
  data-target={value}
  data-suffix={suffix}
>
  <p class="metric-card__number">
    <span class="metric-card__value">{value.toLocaleString('es-CO')}</span>
    <span class="metric-card__suffix">{suffix}</span>
  </p>
  <p class="metric-card__label">{label}</p>
  {description && <p class="metric-card__desc">{description}</p>}
</article>

<style>
  .metric-card {
    background: var(--color-bg-soft);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    border-top: 3px solid var(--color-primary);
    box-shadow: var(--shadow-md);
    transition: transform var(--duration-normal) var(--easing-smooth), box-shadow var(--duration-normal);
  }

  .metric-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .metric-card__number {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: var(--weight-black);
    color: var(--color-text-primary);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .metric-card__suffix {
    color: var(--color-primary-dark);
  }

  .metric-card__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
  }

  .metric-card__desc {
    font-size: var(--text-caption);
    color: var(--color-text-muted);
  }
</style>
