---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import SectionLabel from '@/components/ui/SectionLabel.astro';
import Button from '@/components/ui/Button.astro';
import ImpactExchange from '@/components/sections/ImpactExchange.astro';

const layers = [
  {
    num: '01',
    product: 'ELISA®',
    tag: 'Hardware',
    desc: 'Poste solar autónomo con panel de 100W, batería de litio y WiFi integrado. 7,000+ nodos activos en 35 países. La capa física que hace posible todo lo demás.',
    color: 'var(--color-accent)',
  },
  {
    num: '02',
    product: 'ELIoT®',
    tag: 'IoT Node',
    desc: 'Sensor inteligente embebido en cada ELISA®. Transmite telemetría en tiempo real vía Starlink: energía generada, conectividad activa, beneficiarios y CO₂ evitado — sin intermediarios.',
    color: 'var(--color-primary)',
  },
  {
    num: '03',
    product: 'Impact Exchange®',
    tag: 'SaaS Platform',
    desc: 'Dashboard de Impact Intelligence que consolida todos los datos físicos. AI audita la telemetría y genera reportes CSRD, GRI y GHG Protocol automáticamente. Acceso 24/7 para equipos de sostenibilidad.',
    color: 'var(--color-primary)',
  },
  {
    num: '04',
    product: '$LITRO Protocol',
    tag: 'DePIN',
    desc: 'Cada nodo verificado genera tokens de impacto físico respaldados por datos reales. El primer protocolo DePIN de energía solar certificable.',
    color: 'var(--color-primary-dark)',
  },
];

const pricingFeatures = [
  'Calculado por volumen de nodos desplegados',
  'Incluye hardware ELISA® + ELIoT® + plataforma',
  'Dashboard Impact Exchange® incluido',
  'Reportes CSRD, GRI y GHG Protocol automáticos',
  'Data licensing disponible para reportes de inversión',
  'Soporte dedicado + SLA según acuerdo',
];
---

<BaseLayout
  title="Impact Exchange® — Litro de Luz® | Dashboard de Impact Intelligence"
  description="El primer dashboard de impacto verificable del mundo. Telemetría IoT en tiempo real, datos ESG auditados por AI y reportes CSRD automáticos desde infraestructura física."
>
  <Navbar />
  <main>

    <!-- Hero -->
    <section class="ie-hero" aria-labelledby="ie-hero-heading">
      <div class="ie-hero__bg" aria-hidden="true">
        <div class="ie-hero__glow ie-hero__glow--1"></div>
        <div class="ie-hero__glow ie-hero__glow--2"></div>
        <div class="ie-hero__grid"></div>
      </div>
      <div class="container ie-hero__inner">
        <div class="ie-hero__content">
          <SectionLabel light>Impact Exchange®</SectionLabel>
          <h1 id="ie-hero-heading" class="ie-hero__headline">
            Tu ESG respaldado<br />
            <span class="ie-hero__accent">por hardware.</span>
          </h1>
          <p class="ie-hero__subhead">
            Infraestructura física real + AI. Reportes que resisten cualquier auditoría.
            Cada dato viene de un nodo activo en campo — nada de estimaciones.
          </p>
          <div class="ie-hero__badges" role="list" aria-label="Certificaciones">
            <span class="ie-hero__badge" role="listitem">CSRD Compliant</span>
            <span class="ie-hero__badge" role="listitem">GRI Verified</span>
            <span class="ie-hero__badge" role="listitem">GHG Protocol</span>
            <span class="ie-hero__badge" role="listitem">AI-Audited</span>
          </div>
          <div class="ie-hero__ctas">
            <Button href="/empresas#contacto" size="lg" arrow>
              Schedule a Demo
            </Button>
            <Button href="#plataforma" variant="ghost" size="lg">
              Ver la plataforma
            </Button>
          </div>
        </div>

        <ul class="ie-hero__stats" role="list" aria-label="Métricas clave">
          <li class="ie-hero__stat">
            <span class="ie-hero__stat-val">7,000+</span>
            <span class="ie-hero__stat-lbl">Nodos activos</span>
          </li>
          <li class="ie-hero__stat">
            <span class="ie-hero__stat-val">98.2%</span>
            <span class="ie-hero__stat-lbl">Uptime de red</span>
          </li>
          <li class="ie-hero__stat">
            <span class="ie-hero__stat-val">$12.4M</span>
            <span class="ie-hero__stat-lbl">ESG value tracked</span>
          </li>
          <li class="ie-hero__stat">
            <span class="ie-hero__stat-val">35</span>
            <span class="ie-hero__stat-lbl">Países</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Dashboard + Features (reutiliza la sección de home sin header redundante) -->
    <div id="plataforma">
      <ImpactExchange compact />
    </div>

    <!-- Arquitectura de la plataforma -->
    <section class="section section--soft ie-layers" id="arquitectura" aria-labelledby="ie-layers-heading">
      <div class="container">
        <div class="ie-layers__header gsap-hidden">
          <SectionLabel>Arquitectura</SectionLabel>
          <h2 id="ie-layers-heading" class="ie-layers__headline">
            4 capas. Un solo ecosistema<br />de impacto verificable.
          </h2>
          <p class="ie-layers__sub">
            Desde el hardware en campo hasta el reporte regulatorio — cada capa alimenta a la siguiente
            con datos físicos reales.
          </p>
        </div>

        <ol class="ie-layers__list" aria-label="Capas del ecosistema">
          {layers.map((layer, i) => (
            <li class="ie-layers__item gsap-hidden">
              <div class="ie-layers__num" style={`--layer-color: ${layer.color}`} aria-hidden="true">
                {layer.num}
              </div>
              <div class="ie-layers__body">
                <div class="ie-layers__product-row">
                  <h3 class="ie-layers__product">{layer.product}</h3>
                  <span class="ie-layers__tag">{layer.tag}</span>
                </div>
                <p class="ie-layers__desc">{layer.desc}</p>
              </div>
              {i < layers.length - 1 && (
                <div class="ie-layers__arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 40" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 0 V32 M4 24 L12 40 L20 24"
                          stroke="var(--color-primary)" stroke-width="1.5"
                          stroke-linecap="round" stroke-linejoin="round"
                          fill="none" opacity="0.35"/>
                  </svg>
                </div>
              )}
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Pricing -->
    <section class="section section--dark ie-pricing" id="pricing" aria-labelledby="ie-pricing-heading">
      <div class="container">
        <div class="ie-pricing__inner gsap-hidden">
          <div class="ie-pricing__copy">
            <SectionLabel light>Inversión</SectionLabel>
            <h2 id="ie-pricing-heading" class="ie-pricing__headline">
              Precios según<br />tu operación.
            </h2>
            <p class="ie-pricing__sub">
              Cada despliegue es distinto. El costo depende del volumen de nodos,
              la región y el nivel de integración con tus sistemas de reporte.
              Sin sorpresas — todo incluido desde el hardware hasta la plataforma.
            </p>
            <Button href="/empresas#contacto" size="lg" arrow>
              Hablar con el equipo
            </Button>
          </div>

          <ul class="ie-pricing__features" role="list">
            {pricingFeatures.map(f => (
              <li class="ie-pricing__feature">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="ie-pricing__check">
                  <circle cx="9" cy="9" r="8.25" stroke="rgba(56,182,255,0.3)" stroke-width="1.5"/>
                  <path d="M5.5 9l2.5 2.5L12.5 6" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="section section--primary ie-final-cta" aria-labelledby="ie-cta-heading">
      <div class="container ie-final-cta__inner">
        <h2 id="ie-cta-heading" class="ie-final-cta__headline gsap-hidden">
          ¿Listo para medir impacto<br />con datos reales?
        </h2>
        <p class="ie-final-cta__sub gsap-hidden">
          Agenda una demo de 30 minutos y ve cómo Impact Exchange®
          transforma los datos de tus nodos en evidencia CSRD lista para auditoría.
        </p>
        <div class="ie-final-cta__ctas gsap-hidden">
          <Button href="/empresas#contacto" size="lg" arrow>
            Schedule a Demo
          </Button>
          <Button href="/" variant="ghost" size="lg">
            Ver toda la plataforma
          </Button>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ delay: 0.1 });
  tl.fromTo('.ie-hero__content > *',
    { opacity: 0, y: 28 },
    { opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out' }
  );
  tl.fromTo('.ie-hero__stats',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' },
    '-=0.3'
  );

  gsap.fromTo('.ie-layers__header', { opacity: 0, y: 28 }, {
    opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
    scrollTrigger: { trigger: '.ie-layers', start: 'top 78%' },
  });

  gsap.fromTo('.ie-layers__item', { opacity: 0, y: 28 }, {
    opacity: 1, y: 0, duration: 0.65, stagger: 0.15, ease: 'power3.out',
    scrollTrigger: { trigger: '.ie-layers__list', start: 'top 80%' },
  });

  gsap.fromTo('.ie-pricing__inner', { opacity: 0, y: 28 }, {
    opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
    scrollTrigger: { trigger: '.ie-pricing', start: 'top 78%' },
  });

  gsap.fromTo('.ie-final-cta .gsap-hidden', { opacity: 0, y: 28 }, {
    opacity: 1, y: 0, duration: 0.7, stagger: 0.15, ease: 'power3.out',
    scrollTrigger: { trigger: '.ie-final-cta', start: 'top 75%' },
  });
</script>

<style>
  /* ── Hero ── */
  .ie-hero {
    position: relative;
    background: var(--color-bg-dark);
    color: var(--color-white);
    padding-block: var(--space-24);
    overflow: hidden;
  }

  .ie-hero__bg { position: absolute; inset: 0; pointer-events: none; }

  .ie-hero__glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .ie-hero__glow--1 {
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(56,182,255,0.13) 0%, transparent 65%);
    top: -10%; left: -10%;
    filter: blur(70px);
  }

  .ie-hero__glow--2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(232,98,26,0.08) 0%, transparent 65%);
    bottom: -5%; right: 5%;
    filter: blur(60px);
  }

  .ie-hero__grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(56,182,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56,182,255,0.04) 1px, transparent 1px);
    background-size: 56px 56px;
  }

  .ie-hero__inner {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    gap: var(--space-16);
  }

  .ie-hero__content { max-width: 680px; }

  .ie-hero__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    letter-spacing: -0.02em;
    color: var(--color-white);
    margin-top: var(--space-3);
    margin-bottom: var(--space-6);
    line-height: var(--leading-tight);
  }

  .ie-hero__accent { color: var(--color-primary); }

  .ie-hero__subhead {
    font-size: var(--text-body-lg);
    color: rgba(255,255,255,0.62);
    line-height: var(--leading-normal);
    max-width: 560px;
    margin-bottom: var(--space-6);
  }

  .ie-hero__badges {
    display: flex; flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .ie-hero__badge {
    background: rgba(56,182,255,0.10);
    border: 1px solid rgba(56,182,255,0.30);
    border-radius: var(--radius-sm);
    font-size: var(--text-caption);
    color: var(--color-primary);
    padding: 4px 10px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    font-weight: var(--weight-semibold);
  }

  .ie-hero__ctas {
    display: flex; flex-wrap: wrap;
    gap: var(--space-4);
  }

  .ie-hero__stats {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 480px;
  }

  @media (min-width: 600px) {
    .ie-hero__stats { grid-template-columns: repeat(4, 1fr); max-width: 100%; }
  }

  .ie-hero__stat {
    display: flex; flex-direction: column; gap: 4px;
    padding-top: var(--space-4);
    border-top: 2px solid rgba(56,182,255,0.25);
  }

  .ie-hero__stat-val {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.5vw, 38px);
    font-weight: var(--weight-black);
    color: var(--color-white);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .ie-hero__stat-lbl {
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  /* ── Arquitectura / Layers ── */
  .ie-layers__header {
    max-width: 600px;
    margin-bottom: var(--space-16);
  }

  .ie-layers__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-top: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .ie-layers__sub {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 520px;
  }

  .ie-layers__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ie-layers__item {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--space-6);
    align-items: start;
    position: relative;
  }

  @media (min-width: 768px) {
    .ie-layers__list {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
      align-items: start;
    }

    .ie-layers__item {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      padding: 0 var(--space-4);
    }
  }

  .ie-layers__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--layer-color, var(--color-primary));
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: var(--weight-black);
    flex-shrink: 0;
  }

  .ie-layers__product-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }

  .ie-layers__product {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .ie-layers__tag {
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-dark);
    background: var(--color-primary-light);
    border-radius: var(--radius-pill);
    padding: 2px 8px;
  }

  .ie-layers__desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .ie-layers__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4) 0;
    margin-left: 28px;
  }

  @media (min-width: 768px) {
    .ie-layers__arrow {
      margin-left: 0;
      padding: 14px 0 0;
    }

    .ie-layers__arrow svg {
      width: 24px; height: 40px;
    }
  }

  .ie-layers__arrow svg { width: 24px; height: 40px; }

  /* On mobile show vertical arrows */
  @media (max-width: 767px) {
    .ie-layers__item { margin-bottom: var(--space-6); }
  }

  /* ── Pricing ── */
  .ie-pricing__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (min-width: 768px) {
    .ie-pricing__inner { grid-template-columns: 1fr 1fr; }
  }

  .ie-pricing__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .ie-pricing__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    letter-spacing: -0.02em;
    color: var(--color-white);
    margin-top: var(--space-3);
    line-height: var(--leading-tight);
  }

  .ie-pricing__sub {
    font-size: var(--text-body-lg);
    color: rgba(255,255,255,0.6);
    line-height: var(--leading-normal);
    max-width: 440px;
  }

  .ie-pricing__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .ie-pricing__feature {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    font-size: var(--text-body);
    color: rgba(255,255,255,0.75);
    line-height: var(--leading-normal);
  }

  .ie-pricing__check { flex-shrink: 0; margin-top: 2px; }

  /* ── Final CTA ── */
  .ie-final-cta__inner {
    text-align: center;
    padding-block: var(--space-24);
  }

  .ie-final-cta__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }

  .ie-final-cta__sub {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 520px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .ie-final-cta__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }
</style>
