---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/sections/Hero.astro';
import ImpactNumbers from '@/components/sections/ImpactNumbers.astro';
import ImpactMapSection from '@/components/sections/ImpactMapSection.astro';
import Problem from '@/components/sections/Problem.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import ElisaTeaser from '@/components/sections/ElisaTeaser.astro';
import ForCompanies from '@/components/sections/ForCompanies.astro';
import Marcas from '@/components/sections/Marcas.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
---

<BaseLayout>
  <Navbar />
  <main>
    <Hero />
    <ImpactNumbers />
    <ImpactMapSection mode="teaser" />
    <Problem />
    <HowItWorks />
    <ElisaTeaser />
    <ForCompanies />
    <Marcas mode="teaser" />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
