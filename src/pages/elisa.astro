---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import Elisa from '@/components/sections/Elisa.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout
  title="ELISA® — El poste solar autónomo | Litro de Luz®"
  description="ELISA® es la infraestructura solar que lleva luz e internet a comunidades sin acceso a energía. 100W · 150Ah LiFePO₄ · WiFi 100m · 15+ años de vida útil."
>
  <Navbar />
  <main>

    <!-- Hero de página -->
    <section class="elisa-hero" aria-labelledby="elisa-page-heading">
      <div class="elisa-hero__bg" aria-hidden="true">
        <div class="elisa-hero__glow"></div>
      </div>
      <div class="container elisa-hero__inner">
        <p class="elisa-hero__back">
          <a href="/" class="elisa-hero__back-link">← Inicio</a>
        </p>
        <p class="elisa-hero__label">El producto</p>
        <h1 id="elisa-page-heading" class="elisa-hero__title">
          ELISA®
        </h1>
        <p class="elisa-hero__sub">
          El poste solar autónomo que combina energía, iluminación e internet
          en una infraestructura compacta. Sin red eléctrica. Sin obra civil.
          Lista en 8 horas.
        </p>
        <div class="elisa-hero__ctas">
          <Button href="/empresas#contacto" size="lg" arrow>
            Solicita una demo
          </Button>
          <Button href="#specs" variant="ghost" size="lg">
            Ver especificaciones
          </Button>
        </div>
      </div>
    </section>

    <!-- Sección de specs completa -->
    <div id="specs">
      <Elisa />
    </div>

    <!-- Cierre -->
    <section class="section section--primary elisa-close" aria-labelledby="elisa-close-heading">
      <div class="container elisa-close__inner">
        <h2 id="elisa-close-heading" class="elisa-close__headline">
          ¿Listo para instalar<br />ELISA® en tu comunidad?
        </h2>
        <p class="elisa-close__sub">
          Empresas, fundaciones y gobiernos pueden financiar instalaciones de ELISA®
          con impacto ESG certificado.
        </p>
        <Button href="/empresas#contacto" size="lg" arrow>
          Habla con nuestro equipo
        </Button>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero de página ── */
  .elisa-hero {
    position: relative;
    background: var(--color-bg-dark);
    color: var(--color-white);
    padding-block: var(--space-24);
    overflow: hidden;
  }

  .elisa-hero__bg { position: absolute; inset: 0; pointer-events: none; }

  .elisa-hero__glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(56,182,255,0.14) 0%, transparent 65%);
    bottom: -20%;
    left: -8%;
    filter: blur(60px);
    border-radius: 50%;
  }

  .elisa-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .elisa-hero__back {
    margin-bottom: var(--space-8);
  }

  .elisa-hero__back-link {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast);
  }

  .elisa-hero__back-link:hover { color: var(--color-white); }

  .elisa-hero__label {
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .elisa-hero__title {
    font-size: clamp(56px, 10vw, 112px);
    font-weight: var(--weight-black);
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-white);
    margin-bottom: var(--space-6);
  }

  .elisa-hero__sub {
    font-size: var(--text-body-lg);
    color: rgba(255,255,255,0.6);
    line-height: var(--leading-normal);
    max-width: 540px;
    margin-bottom: var(--space-8);
  }

  .elisa-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  /* ── Cierre ── */
  .elisa-close__inner {
    text-align: center;
    padding-block: var(--space-16);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .elisa-close__headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-black);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .elisa-close__sub {
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    max-width: 480px;
    line-height: var(--leading-normal);
  }
</style>
